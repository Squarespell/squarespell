# Supabase Configuration (Staging)
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_staging_anon_key_here

# Authentication (Staging)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_staging_clerk_publishable_key_here

# Backend API (Staging)
NEXT_PUBLIC_API_URL=https://api-staging.yourdomain.com

# Error Tracking (Staging)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-sentry-account.ingest.sentry.io/your-frontend-project-id
