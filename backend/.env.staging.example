# Supabase Configuration (Staging)
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_staging_service_role_key_here

# Authentication (Staging)
CLERK_SECRET_KEY=sk_test_your_staging_clerk_secret_key_here

# Payment Processing (Staging)
STRIPE_SECRET_KEY=sk_test_your_staging_stripe_secret_key_here

# Email Service (Staging)
RESEND_API_KEY=re_your_staging_resend_api_key_here

# AI Service (Staging)
ANTHROPIC_API_KEY=sk-ant-your_staging_anthropic_api_key_here

# Redis Cache (Staging)
UPSTASH_REDIS_URL=https://your-staging-redis-url.upstash.io
UPSTASH_REDIS_TOKEN=your_staging_redis_token_here

# Error Tracking (Staging)
SENTRY_DSN=https://your-key@your-sentry-account.ingest.sentry.io/your-project-id

# Server Configuration (Staging)
PORT=3001
FRONTEND_URL=https://staging-frontend.yourdomain.com
CORS_ORIGIN=https://staging-frontend.yourdomain.com
